# ===== バックエンド環境変数 =====

# Anthropic API Key（マイソク解析用）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Notion連携
NOTION_TOKEN=secret_xxxxx
NOTION_DATABASE_ID=xxxxx
NOTION_MAPPING_DATABASE_ID=xxxxx

# サーバー設定
PORT=3001

# フロントエンドURL（CORS許可用、カンマ区切りで複数可）
# FRONTEND_URL=https://bukaku-frontend.up.railway.app

# プラットフォーム認証情報（JSON文字列）
# Railway等のデプロイ環境ではこの環境変数からcredentials.jsonを生成
# CREDENTIALS_JSON={"platforms":{...},"priority":[...]}

# アプリ認証
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ITANDI個別設定（オプション）
# ITANDI_EMAIL=
# ITANDI_PASSWORD=

# Base64エンコードした credentials.json（デプロイ環境用）
# CREDENTIALS_JSON_B64=

# ===== フロントエンド環境変数 =====

# バックエンドURL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
