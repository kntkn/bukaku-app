{
  "itandi": {
    "name": "ITANDI BB",
    "comment": "itandibb.com/topにアクセス→未ログインならitandi-accounts.comにリダイレクト",
    "login": {
      "steps": [
        { "action": "wait", "ms": 3000 },
        { "action": "waitFor", "selector": "input#email", "timeout": 10000 },
        { "action": "fill", "selector": "input#email", "value": "${email}" },
        { "action": "fill", "selector": "input#password", "value": "${password}" },
        { "action": "click", "selector": "input[type='submit']" },
        { "action": "wait", "ms": 5000 }
      ],
      "successCheck": { "urlContains": "itandibb.com", "urlNotContains": ["login", "itandi-accounts"] }
    },
    "search": {
      "preSteps": [
        { "action": "waitFor", "selector": "text=リスト検索", "timeout": 10000 },
        { "action": "click", "selector": "text=リスト検索", "index": 0 },
        { "action": "wait", "ms": 3000 }
      ],
      "steps": [
        { "action": "waitFor", "selector": "input[name='building_name:match']", "timeout": 10000 },
        { "action": "fill", "selector": "input[name='building_name:match']", "value": "${propertyName}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "ms": 5000 }
      ],
      "roomNumberSteps": [
        { "action": "fill", "selector": "input[name='room_number:match'], input[name='room_no'], input[placeholder*='部屋'], input[placeholder*='号室']", "value": "${roomNumber}", "optional": true }
      ],
      "resultSelector": ".itandi-bb-ui__Box.css-1tqsbsd",
      "resultExtraction": {
        "statusPatterns": {
          "available": ["募集中"],
          "applied": ["申込あり", "商談中"],
          "unavailable": ["成約済", "募集終了"]
        },
        "adPatterns": ["広告費", "AD"],
        "viewingPatterns": ["内見可", "即内見"]
      }
    }
  },
  "ierabu": {
    "name": "いえらぶBB",
    "comment": "ログイン後/ielovebb/top/に遷移、input#renmで物件名検索",
    "login": {
      "steps": [
        { "action": "waitFor", "selector": "input[placeholder='ログインIDを入力']", "timeout": 15000 },
        { "action": "fill", "selector": "input[placeholder='ログインIDを入力']", "value": "${email}" },
        { "action": "fill", "selector": "input[placeholder='パスワードを入力']", "value": "${password}" },
        { "action": "click", "selector": "input#loginButton" },
        { "action": "wait", "ms": 5000 }
      ],
      "successCheck": { "urlNotContains": ["login"] }
    },
    "search": {
      "preSteps": [
        { "action": "waitFor", "selector": "input#renm", "timeout": 10000 }
      ],
      "steps": [
        { "action": "fill", "selector": "input#renm", "value": "${propertyName}" },
        { "action": "click", "selector": "button#freeBknSearch" },
        { "action": "wait", "ms": 5000 }
      ],
      "resultSelector": ".property-list-item, .search-result-item, tr.property-row, .bukken-item, table tbody tr",
      "resultExtraction": {
        "statusPatterns": {
          "available": ["募集中", "空室", "即入居可"],
          "applied": ["申込中", "申込あり", "商談中", "交渉中"],
          "unavailable": ["成約済", "成約", "募集終了", "終了"]
        },
        "adPatterns": ["AD", "広告料", "業者報酬"],
        "viewingPatterns": ["内見可", "即内見", "内覧可"]
      }
    }
  },
  "atbb": {
    "name": "ATBB",
    "comment": "複雑なポータル構造。物件検索画面への遷移に追加調査が必要",
