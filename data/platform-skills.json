    "search": {
      "comment": "ポータルからの物件検索ナビゲーションが複雑。追加調査が必要",
      "requiresManualNavigation": true
    }
  },
  "essquare": {
    "name": "いい物件",
    "comment": "React/MUI SPA。検索UIが動的生成のため標準セレクタが機能しない。追加調査が必要",
    "complexNavigation": true,
    "login": {
      "steps": [
        { "action": "waitFor", "selector": "button:has-text('いい生活アカウントでログイン')", "timeout": 15000 },
        { "action": "click", "selector": "button:has-text('いい生活アカウントでログイン')" },
        { "action": "wait", "ms": 3000 },
        { "action": "waitFor", "selector": "input#username", "timeout": 15000 },
        { "action": "fill", "selector": "input#username", "value": "${email}" },
        { "action": "fill", "selector": "input#password", "value": "${password}" },
        { "action": "click", "selector": "button[name='action']" },
        { "action": "wait", "ms": 5000 }
      ],
      "successCheck": { "urlContains": "es-square.net" }
    },
    "search": {
      "comment": "MUIベースのSPA。検索入力のセレクタが動的。追加調査が必要",
      "requiresManualNavigation": true
    }
  },
  "ambition": {
    "name": "アンビション",
