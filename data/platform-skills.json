{
  "itandi": {
    "name": "ITANDI BB",
    "comment": "itandibb.com/topにアクセス→未ログインならitandi-accounts.comにリダイレクト。たまにトップページに戻されることがあり、その場合はページ上部のログインボタンから進む",
    "login": {
      "steps": [
        { "action": "waitFor", "selector": "input#email, input[placeholder*='example@itandi.co.jp']", "timeout": 10000 },
        { "action": "fill", "selector": "input#email, input[placeholder*='example@itandi.co.jp']", "value": "${email}" },
        { "action": "fill", "selector": "input#password, input[type='password']", "value": "${password}" },
        { "action": "click", "selector": "input[type='submit'], button:has-text('ログイン')" },
        { "action": "smartWait", "selector": "text=リスト検索", "timeout": 10000 }
      ],
      "retryLogin": {
        "comment": "トップページに戻された場合、上部のログインボタンをクリックしてログインフローを再開",
        "trigger": { "urlContains": "itandibb.com/top" },
        "steps": [
          { "action": "click", "selector": "a:has-text('ログイン'), a[href*='login'], button:has-text('ログイン')" },
          { "action": "smartWait", "selector": "input#email, input[placeholder*='example@itandi.co.jp']", "timeout": 10000 },
          { "action": "fill", "selector": "input#email, input[placeholder*='example@itandi.co.jp']", "value": "${email}" },
          { "action": "fill", "selector": "input#password, input[type='password']", "value": "${password}" },
          { "action": "click", "selector": "input[type='submit'], button:has-text('ログイン')" },
          { "action": "smartWait", "selector": "text=リスト検索", "timeout": 10000 }
        ]
      },
      "afterLoginCheck": { "action": "goto", "url": "https://itandibb.com/top", "wait": 2000 },
      "successCheck": { "urlContains": "itandibb.com", "urlNotContains": ["login", "itandi-accounts"], "elementExists": "text=リスト検索" }
    },
    "search": {
      "preSteps": [
        { "action": "goto", "url": "https://itandibb.com/top" },
        { "action": "smartWait", "selector": "text=リスト検索", "timeout": 10000 },
        { "action": "click", "selector": "text=リスト検索", "index": 0 },
        { "action": "smartWait", "selector": "input[name='building_name:match']", "timeout": 10000 }
      ],
      "steps": [
        { "action": "fill", "selector": "input[name='building_name:match']", "value": "${propertyName}", "timeout": 10000 },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "ms": 2000 },
        { "action": "smartWait", "selector": "[class*='ListResultArea']", "timeout": 5000 }
      ],
      "roomNumberSteps": [
        { "action": "fill", "selector": "input[name='room_number:match'], input[name='room_no'], input[placeholder*='部屋'], input[placeholder*='号室']", "value": "${roomNumber}", "optional": true }
      ],
      "resultSelector": "[class*='ListResultArea']",
      "resultExtraction": {
        "statusPatterns": {
          "available": ["募集中"],
          "applied": ["申込あり", "商談中"],
          "unavailable": ["成約済", "募集終了"]
        },
        "adPatterns": ["広告費", "AD"],
        "adSelector": ".itandi-bb-ui__Flex > span:first-child",
        "adComment": "部屋行の最終カラム内、最初のspan=AD値（なし/100%等）",
        "viewingPatterns": ["内見可", "即内見"],
        "applicationBadgeSelector": "[class*='MuiBadge-badge']"
      }
    }
  },
  "ierabu": {
    "name": "いえらぶBB",
    "comment": "ログイン後/ielovebb/top/に遷移、input#renmで物件名検索",
    "login": {
      "steps": [
        { "action": "waitFor", "selector": "input[placeholder='ログインIDを入力']", "timeout": 5000 },
        { "action": "fill", "selector": "input[placeholder='ログインIDを入力']", "value": "${email}" },
        { "action": "fill", "selector": "input[placeholder='パスワードを入力']", "value": "${password}" },
        { "action": "click", "selector": "input#loginButton" },
        { "action": "smartWait", "selector": "input#renm", "timeout": 5000 }
      ],
      "successCheck": { "urlNotContains": ["login"] }
    },
    "search": {
      "preSteps": [
        { "action": "goto", "url": "https://bb.ielove.jp/ielovebb/top/index/type/01/" },
        { "action": "smartWait", "selector": "input#renm", "timeout": 5000 }
      ],
      "steps": [
        { "action": "fill", "selector": "input#renm", "value": "${propertyName}" },
        { "action": "click", "selector": "button#freeBknSearch" },
        { "action": "smartWait", "selector": "tbody.bkn-clickable-area", "timeout": 5000 }
      ],
      "resultSelector": "tbody.bkn-clickable-area",
      "resultExtraction": {
        "statusPatterns": {
          "available": ["募集中", "空室", "即入居可"],
          "applied": ["申込中", "申込あり", "商談中", "交渉中"],
          "unavailable": ["成約済", "成約", "募集終了", "終了"]
        },
        "adPatterns": ["AD", "広告料", "広告費", "業者報酬"],
        "adSelector": "td.bkn_info > div:nth-child(4) > p",
        "adComment": "td.bkn_info内の4番目のdiv内のp要素。テキスト例:「広告費： 140％」「広告費： -」",
        "viewingPatterns": ["内見可", "即内見", "内覧可"]
      }
    }
  },
  "atbb": {
    "name": "ATBB",
    "comment": "ポータル(members.athome.jp)→フォームPOST(target=_self)→ATBB SSO→ConcurrentLogin強制解除→検索ページ。searchareaはdisplay:noneで隠れているためevaluateで表示。フリーワード検索(freeWordSearchSubject)で物件名検索",
    "login": {
      "steps": [
        { "action": "waitFor", "selector": "input#loginFormText", "timeout": 5000 },
        { "action": "fill", "selector": "input#loginFormText", "value": "${id}" },
        { "action": "fill", "selector": "input#passFormText", "value": "${password}" },
        { "action": "click", "selector": "input#loginSubmit" },
        { "action": "smartWait", "timeout": 3000 }
      ],
      "successCheck": { "urlContains": "portal" }
    },
    "search": {
      "alwaysRunPreSteps": true,
      "preSteps": [
        { "action": "goto", "url": "https://members.athome.jp/portal" },
        { "action": "smartWait", "selector": "form[method='post']", "timeout": 10000 },
        { "action": "evaluate", "script": "const f=document.querySelector('form[method=\"post\"]');if(f){f.action='/atbb/nyushuSearch?from=global_menu_bukkenKensaku';f.target='_self';f.submit()}", "waitForNavigation": true, "timeout": 30000 },
        { "action": "wait", "ms": 3000 },
        { "action": "evaluate", "script": "if(document.body.textContent.includes('他のユーザー'))document.forms[0].submit()", "optional": true },
        { "action": "smartWait", "selector": "input[name='atbbShumokuDaibunrui']", "timeout": 15000 },
        { "action": "evaluate", "script": "var r=document.querySelector('input[name=\"atbbShumokuDaibunrui\"][value=\"06\"]');if(r){r.checked=true;r.click()}var a=document.getElementById('searcharea');if(a)a.style.display=''" },
        { "action": "wait", "ms": 500 },
        { "action": "smartWait", "selector": "input#freeWordSearchSubject", "timeout": 5000 }
      ],
      "steps": [
        { "action": "fill", "selector": "input#freeWordSearchSubject", "value": "${propertyName}" },
        { "action": "click", "selector": "input#freeWordSearchSubjectButton" },
        { "action": "smartWait", "selector": ".property_card", "timeout": 15000 }
      ],
      "resultSelector": ".property_card",
      "resultExtraction": {
        "statusPatterns": {
          "available": ["募集中", "空室", "入居可", "空き"],
          "applied": ["申込中", "申込あり", "商談中"],
          "unavailable": ["成約済", "成約", "終了", "募集終了"]
        },
        "adPatterns": ["AD", "広告料", "広告費", "広告転載"],
        "adSelector": ".property_data",
        "adComment": "物件名=p.name, 賃料=画像化(txt2img), 広告転載=property_data内, 転載不可/可",
        "viewingPatterns": ["内見可", "内覧可"]
      }
    }
  },
